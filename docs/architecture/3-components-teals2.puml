@startuml 3-components-teals

'skinparam linetype ortho
'skinparam nodesep 80
'skinparam ranksep 150

skinparam nodesep 70
skinparam ranksep 130

title "Kryptograficky verifikovatelný auditní log: Komponenty"

[Information System] as Producer <<Producer>>
[Audit Client] as Client <<Container>>
actor "Auditor" as Auditor

package "Audit Log Server" {
    package "Transport Layer" {
        [IngestionServer] as GrpcIngestion <<gRPC Handler>>
        [QueryServer] as GrpcQuery <<gRPC Handler>>
        [ProofServer] as GrpcProof <<gRPC Handler>>
        [KeyServer] as GrpcKey <<gRPC Handler>>
        [Worker] as Worker <<Background Worker>>
    }

    package "Service Layer" {
        [IngestionService] as IngestionService <<Service>>
        [QueryService] as QueryService <<Service>>
        [ProofService] as ProofService <<Service>>
        [CheckpointService] as CheckpointService <<Service>>
        [ProducerKeyService] as ProducerKeyService <<Service>>
    }

   package "Infrastructure Layer" {
        [ProducerKeyRegistry] as KeyRepo <<Repository>>
        [AuditLog] as LogRepo <<Repository>>
        [Ledger] as LedgerRepo <<Repository>>
        [CheckpointStore] as CheckpointRepo <<Repository>>

    }
}

database "Database" as DB

Producer ..> GrpcIngestion: Odesílá \nauditní záznamy\n<<gRPC API>>
Producer ..> GrpcKey: Požadavek na \nregistraci klíče \npro ověření podpisu \nauditních záznamů\n<<gRPC API>>
Client ..> GrpcProof: Získává důkazy a checkpointy\n<<gRPC API>>
Client ..> GrpcQuery: Vyhledává auditní záznamy\n<<gRPC API>>

Auditor .left.> Client: Vyhledává auditní záznamy \na ověřuje důkazy
Producer .[hidden]>Client: "\t\t\t\t\t"

GrpcKey .[hidden]> GrpcIngestion
GrpcKey ..> ProducerKeyService: Registrace klíče \nproducenta pro \nověření podpisu \nauditních záznamů
GrpcIngestion ..> IngestionService: Zpracování \nauditní události\n a ověření podpisu
GrpcProof ..> ProofService: Získání důkazu \no zařazení \nauditního záznamu \na konzistenci \nauditního logu
GrpcProof ..> CheckpointService: Získání \naktuálního \npodepsaného \ncheckpointu
GrpcQuery ..> QueryService: Zpracování \ndotazu \nvyhledávání \nauditních \nzáznamů

Worker ..> CheckpointService: Periodické \nvytváření \npodepsaného \ncheckpointu

ProducerKeyService .down.> KeyRepo: Uložení \nveřejného \nklíče \nproducenta
IngestionService .down.> KeyRepo: Vyhledání \nveřejného klíče \nproducenta
IngestionService .down.> LogRepo: Uložení \nauditního \nzáznamu
IngestionService .down.> LedgerRepo: Uložení \nkryptografické \nstopy auditního \nzáznamu
ProofService .down.> LedgerRepo: Vyhledávání \nkryptografických stop \npro generování \ndůkazů
CheckpointService .down.> CheckpointRepo: Uložení / vyhledání \npodepsaného \ncheckpointu
CheckpointService .down.> LedgerRepo: Čtení aktuálního \nstavu ledgeru
QueryService .down.> LogRepo: Vyhledávání \nauditních \nzáznamů

KeyRepo .down.> DB
LogRepo .down.> DB
LedgerRepo .down.> DB
CheckpointRepo .down.> DB

ProducerKeyService .[hidden]> IngestionService
IngestionService .[hidden]> QueryService

KeyRepo .[hidden]> LogRepo
ProducerKeyService .[hidden].>KeyRepo
ProofService .[hidden].> LedgerRepo

@enduml
